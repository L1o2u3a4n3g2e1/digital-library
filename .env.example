# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=multilingual_library
DB_PORT=3306

# ==========================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ==========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD="your-16-character-app-password"
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=Digital Library

# ==========================================
# SMS CONFIGURATION (SMS Gateway)
# ==========================================
SMS_PROVIDER=smsgateway
SMSGATEWAY_API_KEY=your-smsgateway-api-key
SMSGATEWAY_DEVICE_ID=your-device-id

# ==========================================
# JWT & SECURITY
# ==========================================
JWT_SECRET=your-secret-key-min-32-chars-change-this-in-production
JWT_EXPIRY=86400

# ==========================================
# VERIFICATION SETTINGS
# ==========================================
VERIFICATION_CODE_LENGTH=6
VERIFICATION_CODE_EXPIRY=900

# ==========================================
# APPLICATION SETTINGS
# ==========================================
APP_NAME=Digital Library
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-railway-backend.railway.app
FRONTEND_URL=https://your-vercel-frontend.vercel.app

# ==========================================
# CORS SETTINGS
# ==========================================
ALLOWED_ORIGINS=https://your-vercel-frontend.vercel.app,https://your-railway-backend.railway.app

# ==========================================
# FILE UPLOAD
# ==========================================
MAX_UPLOAD_SIZE=52428800
UPLOAD_DIR=uploads/

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=debug
LOG_FILE=logs/app.log
