# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=multilingual_library
DB_PORT=3306

# ==========================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ==========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD="your-16-character-app-password"
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=Digital Library

# ==========================================
# SMS CONFIGURATION (Optional - Twilio/Africa's Talking)
# ==========================================
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# ==========================================
# JWT & SECURITY
# ==========================================
JWT_SECRET=your-secret-key-min-32-chars-change-this-in-production
JWT_EXPIRY=86400

# ==========================================
# VERIFICATION SETTINGS
# ==========================================
VERIFICATION_CODE_LENGTH=6
VERIFICATION_CODE_EXPIRY=900

# ==========================================
# APPLICATION SETTINGS
# ==========================================
APP_NAME=Digital Library
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ==========================================
# CORS SETTINGS
# ==========================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ==========================================
# FILE UPLOAD
# ==========================================
MAX_UPLOAD_SIZE=52428800
UPLOAD_DIR=uploads/

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=debug
LOG_FILE=logs/app.log
