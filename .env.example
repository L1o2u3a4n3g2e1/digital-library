# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=multilingual_library
DB_PORT=3306

# ==========================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ==========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD="your-16-character-app-password"
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=Digital Library

# ==========================================
# SMS CONFIGURATION
# ==========================================
SMS_PROVIDER=simulated
SMS_MODE=simulated
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=

# ==========================================
# JWT & SECURITY
# ==========================================
JWT_SECRET=your-secret-key-min-32-chars-change-this-in-production
JWT_EXPIRY=7d

# ==========================================
# VERIFICATION SETTINGS
# ==========================================
VERIFICATION_CODE_LENGTH=6
VERIFICATION_CODE_EXPIRY=900

# ==========================================
# APPLICATION SETTINGS
# ==========================================
APP_NAME=Digital Library
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-vercel-project.vercel.app
FRONTEND_URL=https://your-vercel-project.vercel.app

# ==========================================
# CORS SETTINGS
# ==========================================
ALLOWED_ORIGINS=https://your-vercel-project.vercel.app,http://localhost:3000,http://localhost:3001

# ==========================================
# FILE UPLOAD
# ==========================================
MAX_UPLOAD_SIZE=52428800
UPLOAD_DIR=uploads/

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=debug
LOG_FILE=logs/app.log
