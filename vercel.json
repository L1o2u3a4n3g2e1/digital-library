{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install && npm --prefix digital-library-main/digital_library/frontend install",
  "buildCommand": "node scripts/build-frontend.mjs",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/:path((?!.*\\.(?:json|jpg|jpeg|png|gif|css|js|woff|woff2)).*)", "destination": "/index.html" }
  ]
}
