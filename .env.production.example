# ============================================
# Production Environment Configuration
# ============================================
# IMPORTANT: Never commit actual values to git
# Copy this file to .env.production and fill in your values

# ============================================
# Core Application Settings
# ============================================
APP_ENV=production
APP_NAME="Digital Library"
APP_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com
PORT=3001

# ============================================
# Security - CRITICAL
# ============================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-strong-random-secret-32-chars-minimum
JWT_EXPIRY=7d

# CORS - Comma-separated list of allowed origins
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# Database Connection
# ============================================
# Option 1: PostgreSQL with URL
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Option 2: PostgreSQL with individual settings
# PGHOST=your-db-host.com
# PGPORT=5432
# PGUSER=dbuser
# PGPASSWORD=dbpassword
# PGDATABASE=dbname
# POSTGRES_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true

# Option 3: MySQL with URL
# MYSQL_URL=mysql://user:password@host:3306/dbname?ssl=true

# ============================================
# Email Configuration (SMTP)
# ============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME="Digital Library"

# ============================================
# SMS Configuration (Africa's Talking)
# ============================================
SMS_PROVIDER=africastalking
SMS_MODE=live
AT_USERNAME=your-africastalking-username
AT_API_KEY=your-africastalking-api-key
AT_SENDER_ID=DIGITALLIBRARY

# Alternative SMS provider settings (if using different provider)
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# File Upload Settings
# ============================================
MAX_UPLOAD_SIZE=52428800  # 50MB in bytes

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=warn  # debug, info, warn, error
# Set to 'error' in production to reduce logs

# ============================================
# Verification Settings
# ============================================
VERIFICATION_CODE_LENGTH=6
VERIFICATION_CODE_EXPIRY=900  # 15 minutes in seconds

# ============================================
# Password Reset Settings
# ============================================
PASSWORD_RESET_EXPIRY=3600  # 1 hour in seconds
PASSWORD_RESET_SECRET=change-me-to-strong-random-secret

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes in milliseconds
RATE_LIMIT_MAX_REQUESTS=100   # Per IP address

# ============================================
# Session Settings
# ============================================
SESSION_COOKIE_SECURE=true   # HTTPS only
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_MAX_AGE=604800000  # 7 days in milliseconds

# ============================================
# Deployment/CDN Settings
# ============================================
# AWS S3 (if using for file storage)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_S3_BUCKET=your-bucket

# Vercel Deployment (auto-filled if using Vercel)
# VERCEL_ENV=production
# VERCEL_URL=yourdomain.com

# ============================================
# Monitoring & Error Tracking
# ============================================
# Sentry (optional - for error tracking)
# SENTRY_DSN=https://your-sentry-key@sentry.io/project-id

# ============================================
# Feature Flags
# ============================================
ENABLE_GUEST_AUTH=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_SMS_VERIFICATION=true
ENABLE_PASSWORD_RESET=true

# ============================================
# Security Policies
# ============================================
# Set to 'true' to require HTTPS redirects
ENFORCE_HTTPS=true

# Set to 'true' to only allow secure cookies
SECURE_COOKIES=true

# ============================================
# Important Notes
# ============================================
# 1. NEVER commit actual values to git
# 2. Use a secrets manager in production (AWS Secrets Manager, Vault, etc.)
# 3. Rotate secrets regularly
# 4. Use strong random values for all secrets
# 5. Keep database credentials secure
# 6. Monitor access to env files
# 7. Use different secrets for each environment (dev, staging, prod)
# 8. Enable audit logging for secret access

# ============================================
# Verification Checklist
# ============================================
# Before deploying to production:
# ✓ Change all default secrets
# ✓ Set APP_ENV=production
# ✓ Configure database with strong password
# ✓ Set up email service credentials
# ✓ Configure SMS provider
# ✓ Set JWT_SECRET to random value
# ✓ Configure ALLOWED_ORIGINS
# ✓ Enable HTTPS/TLS
# ✓ Set up backups
# ✓ Configure monitoring/logging
# ✓ Test all authentication flows
# ✓ Verify email delivery
# ✓ Verify SMS delivery
# ✓ Run security audit
