FROM php:8.2-cli

# Install system dependencies
RUN apt-get update && apt-get install -y \
    mysql-client \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install PHP extensions
RUN docker-php-ext-install mysqli pdo pdo_mysql

# Set working directory
WORKDIR /app

# Copy backend code
COPY backend/ /app/

# Expose port
EXPOSE 8000

# Start PHP server
CMD ["php", "-S", "0.0.0.0:8000"]
